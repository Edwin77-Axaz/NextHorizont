@page "/dashboard"

<PageTitle>Dashboard - HostHive</PageTitle>

<div style="margin-bottom: 2rem;">
    <h3 style="color: var(--hh-text-muted); font-size: 1rem; font-weight: 600;">Resumen del Día</h3>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
    <div class="hh-card">
        <h4 style="color: var(--hh-text-muted); font-size: 0.875rem; margin-bottom: 0.5rem;">Ventas Totales</h4>
        <div style="font-size: 2rem; font-weight: bold; color: var(--hh-primary);">$1,245.00</div>
    </div>
    
    <div class="hh-card">
        <h4 style="color: var(--hh-text-muted); font-size: 0.875rem; margin-bottom: 0.5rem;">Órdenes Completadas</h4>
        <div style="font-size: 2rem; font-weight: bold; color: var(--hh-text);">42</div>
    </div>
    
    <div class="hh-card">
        <h4 style="color: var(--hh-text-muted); font-size: 0.875rem; margin-bottom: 0.5rem;">Mesas Activas</h4>
        <div style="font-size: 2rem; font-weight: bold; color: var(--hh-secondary);">8 / 15</div>
    </div>
</div>

<div class="hh-card" style="min-height: 300px;">
    <h4 style="color: var(--hh-text); margin-bottom: 1rem;">Actividad Reciente</h4>
    <p style="color: var(--hh-text-muted);">El sistema está conectado. No hay actividad reciente para mostrar todavía.</p>
</div>
