@inject NavigationManager NavigationManager

<div class="sidebar @(IsOpen ? "open" : "")">
    <div class="sidebar-logo">
        <span style="background: var(--hh-primary); color: white; border-radius: 8px; width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center; margin-right: 10px;">H</span>
        HostHive
    </div>
    
    <div class="sidebar-nav">
        <a class="nav-item @(IsActive("/dashboard") ? "active" : "")" @onclick='() => NavigateTo("/dashboard")'>
            <span class="nav-icon">📊</span>
            Dashboard
        </a>
        <a class="nav-item @(IsActive("/products") ? "active" : "")" @onclick='() => NavigateTo("/products")'>
            <span class="nav-icon">🍔</span>
            Productos
        </a>
        <a class="nav-item">
            <span class="nav-icon">🪑</span>
            Mesas
        </a>
        <a class="nav-item">
            <span class="nav-icon">🧾</span>
            Órdenes
        </a>
    </div>
</div>

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    private bool IsActive(string path)
    {
        return NavigationManager.Uri.EndsWith(path, StringComparison.OrdinalIgnoreCase);
    }

    private void NavigateTo(string path)
    {
        NavigationManager.NavigateTo(path);
        // Cerrar menú en móvil tras navegar
        if (IsOpen)
        {
            IsOpen = false;
            IsOpenChanged.InvokeAsync(IsOpen);
        }
    }
}
